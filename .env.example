# ============================================================
# AGENT 03 — Campaign Localizer Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual API keys below
#   3. NEVER commit the .env file to Git (it's in .gitignore)
# ============================================================

# ── DeepL API ─────────────────────────────────────────────
# Get your key: https://www.deepl.com/account/summary
# Free tier:    500,000 chars/month (no credit card needed)
# Pro tier:     Higher limits, from $5.49/month
DEEPL_API_KEY=your_deepl_api_key_here

# ── DeepL Endpoint ────────────────────────────────────────
# Free tier uses api-free.deepl.com
# Pro tier uses api.deepl.com (change if you upgrade)
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate

# ── Anthropic / Claude API ────────────────────────────────
# Get your key: https://console.anthropic.com/settings/keys
# Cost: ~$0.003 per 1000 input tokens (Sonnet 4)
# Typical localisation: ~$0.01 per campaign
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────
# Port your Express server listens on
# If 3000 is taken on your VPS, change to 3001, 4000, etc.
PORT=3000

# ── Optional: Google Ads API (for draft upload) ───────────
# Follow guide: https://developers.google.com/google-ads/api/docs/first-call/overview
# Leave blank if not using Google Ads integration
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── Optional: Meta Ads API (for draft upload) ─────────────
# Guide: https://developers.facebook.com/docs/marketing-api/
# Leave blank if not using Meta integration
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
